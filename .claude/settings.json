{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "KORU_AUTOPUB": "1"
  },
  "permissions": {
    "allow": [
      "Bash(bash .claude/hooks/auto-publish.sh)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git rev-parse:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-publish.sh",
            "timeout": 60,
            "statusMessage": "Publicando no GitHub"
          }
        ]
      }
    ]
  }
}
